{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - MaxFields Result{% endblock %}

{% block body %}
    <div class="float-end">
        <a href="{{ path('maxfield_play', {'path': maxfield.path}) }}" class="btn btn-outline-success">Play</a>
        <a href="{{ path('maxfield_export_mobile', {'path': maxfield.path}) }}" 
           class="btn btn-outline-primary" 
           target="_blank"
           onclick="return exportMobile(this, '{{ maxfield.path }}')"
           id="btnMobile"><i class="bi-phone"></i> Mobile</a>
        <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#variantModal">
            <i class="bi-shuffle"></i> Generar Variante
        </button>
        <a href="{{ path('max_fields_delete', {'id': maxfield.id}) }}" class="btn btn-outline-danger">Delete</a>
    </div>

    <h3>MaxFields for <span id="itemId">{{ maxfield.name }}</span></h3>

    <div
            {{ stimulus_controller('maxfield-view', {
                maxFrames: info.steps|length,
                item: maxfield.path,
                steps: info.steps|json_encode,
            }) }}
    >

        <nav class="nav nav-pills fixed-top bg-dark" id="maxfield-tab-nav">
            <a class="nav-link active" href="#" data-id="maps"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'maps'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                Maps
            </a>
            <a class="nav-link" href="#" data-id="movie"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'movie'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                Movie
            </a>
            <a class="nav-link" href="#" data-id="frames"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'frames'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                Frames
            </a>
            <a class="nav-link" href="#" data-id="frames-mobile"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'frames-mobile'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                Frames M
            </a>
            <a class="nav-link" href="#" data-id="keys"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'keys'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}>
                Keys
            </a>
            <a class="nav-link" href="#" data-id="plan-results"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'plan-results'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                <i class="fas fa-chart-bar"></i> Plan Results
            </a>

            {% for agentInfo in info.agentsInfo %}
                <a class="nav-link" href="#" data-id="agent-{{ agentInfo.agentNumber }}"
                        {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'agent-'~agentInfo.agentNumber}) }}
                        {{ stimulus_target('maxfield-view', 'tabBtn') }}
                        data-agent-num="{{ agentInfo.agentNumber }}"
                >
                    Agent {{ agentInfo.agentNumber }}
                </a>
            {% endfor %}
        </nav>

        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" data-id="maps">
            <div class="row">
                <div class="col">
                    <img src="/maxfields/{{ maxfield.path }}/link_map.png" width="350px" alt="Link Map">
                </div>
                <div class="col">
                    <img src="/maxfields/{{ maxfield.path }}/portal_map.png" width="350px" alt="Portal Map">
                </div>
            </div>
        </div>
        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="movie">
            <img src="/maxfields/{{ maxfield.path }}/plan_movie.gif" width="350px" alt="Link movie">
        </div>
        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="frames">
            <div class="row">
                <div class="col">
                    <button class="btn btn-outline-secondary" {{ stimulus_action('maxfield-view', 'frameStart') }} title="First frame">
                        <span class="bi-skip-backward-fill"></span>
                    </button>
                    <button class="btn btn-outline-secondary" {{ stimulus_action('maxfield-view', 'frameMinus') }}>
                        <span class="bi-dash-lg"></span>
                    </button>
                    <button class="btn btn-outline-secondary" {{ stimulus_action('maxfield-view', 'framePlus') }}>
                        <span class="bi-plus-lg"></span>
                    </button>
                    <button class="btn btn-outline-secondary" {{ stimulus_action('maxfield-view', 'frameEnd') }} title="Last frame">
                        <span class="bi-skip-forward-fill"></span>
                    </button>
                    <span {{ stimulus_target('maxfield-view', 'frameNum') }}>#</span>
                    <div {{ stimulus_target('maxfield-view', 'frameLinkInfo') }}>...</div>
                </div>
                <div class="col border">
                    <img {{ stimulus_target('maxfield-view', 'framesImage') }}
                            src="" alt="Frame" width="350px">
                </div>
            </div>
        </div>
        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="frames-mobile">
            <div style="background: #1a1a1a; color: #e0e0e0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, sans-serif;">
                <div style="display: flex; gap: 8px; justify-content: center; padding: 2px; border-bottom: 1px solid #404040; background: #2d2d2d;">
                    <button class="btn btn-outline-secondary btn-sm" onclick="fmStart()">⏮</button>
                    <button class="btn btn-outline-secondary btn-sm" onclick="fmPrev()">◀</button>
                    <button class="btn btn-outline-secondary btn-sm" onclick="fmNext()">▶</button>
                    <button class="btn btn-outline-secondary btn-sm" onclick="fmEnd()">⏭</button>
                    <span id="fmFrameNum" style="color: #4ade80; font-weight: bold; line-height: 31px;">#</span>
                    <span id="fmTotalFrames" style="color: #9ca3af; font-size: 12px; line-height: 31px;">/ {{ info.steps|length + 1 }}</span>
                </div>
                <div style="padding: 10px;">
                    <img id="fmFrameImg" src="" alt="Frame" style="max-width:100%; height: auto; border-radius: 8px; min-height: 200px; max-height: 50vh;">
                    <div style="background: #262626; border-radius: 8px; padding: 8px; margin: 8px 0; font-size: 13px;">
                        <div style="display: block; margin-bottom: 6px;">
                            <span style="margin-right: 4px; color: #9ca3af; font-size: 12px;">Frame</span>
                            <span id="fmFrameNum2" style="color: #4ade80; font-weight: bold;">#</span>
                            <span style="margin-right: 4px; color: #9ca3af; font-size: 12px;">/</span>
                            <span id="fmTotalFrames2" style="color: #9ca3af; font-size: 12px;">{{ info.steps|length + 1 }}</span>
                            <span id="fmActionType" style="background: #4ade80; color: #1a1a1a; padding: 1px 4px; border-radius: 3px; margin-left: 8px;">LINK</span>
                            <span id="fmDoneBadge" style="display: none; background: #4ade80; color: #1a1a1a; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; margin-left: 8px;">✓ DONE</span>
                        </div>
                        <div style="display: inline-block; margin-right: 12px;"><span style="margin-right: 4px; color: #9ca3af; font-size: 12px;">Link #:</span><span id="fmLinksNum" style="font-size: 13px;">1</span></div>
                        <div style="display: inline-block; margin-right: 12px;"><span style="margin-right: 4px; color: #9ca3af; font-size: 12px;">Agent:</span><span id="fmAgentName" style="color: #4ade80; font-weight: bold; font-size: 13px;">Agent 1</span></div>
                        <div style="display: block; margin-top: 4px;"><span style="margin-right: 4px; color: #9ca3af; font-size: 12px;">From:</span><span id="fmFromPortal" style="font-size: 13px;">Portal (1)</span></div>
                        <div style="display: block;"><span style="margin-right: 4px; color: #9ca3af; font-size: 12px;">To:</span><span id="fmToPortal" style="font-size: 13px;">Portal (2)</span></div>
                    </div>
                </div>
            </div>
            
            <script>
            (function() {
                const steps = {{ info.steps|json_encode|raw }};
                const path = '{{ maxfield.path }}';
                const agentNames = {{ info.agentsInfo|map(a => 'Agent ' ~ a.agentNumber)|json_encode|raw }};
                
                let currentFrame = 0;
                const totalFrames = {{ info.steps|length + 1 }};
                
                function getAgentName(agentNum) {
                    try {
                        const stored = sessionStorage.getItem('maxfield-agents-' + path);
                        if (stored) {
                            const parsed = JSON.parse(stored);
                            if (parsed[agentNum]) return parsed[agentNum];
                        }
                    } catch(e) {}
                    return agentNames[agentNum] || ('Agent ' + agentNum);
                }
                
                function updateUI() {
                    const s = '000000000' + currentFrame;
                    const num = s.substring(s.length - 5);
                    document.getElementById('fmFrameImg').src = '/maxfields/' + path + '/frames/frame_' + num + '.gif';
                    document.getElementById('fmFrameNum').textContent = (currentFrame + 1);
                    document.getElementById('fmFrameNum2').textContent = (currentFrame + 1);
                    document.getElementById('fmTotalFrames').textContent = ' / ' + totalFrames;
                    document.getElementById('fmTotalFrames2').textContent = ' / ' + totalFrames;
                    
                    if (currentFrame > 0 && steps && steps[currentFrame - 1]) {
                        const step = steps[currentFrame - 1];
                        const actionType = step.action === 2 || (!step.linkNum) ? 'MOVE' : 'LINK';
                        const actionEl = document.getElementById('fmActionType');
                        actionEl.textContent = actionType;
                        actionEl.style.background = actionType === 'LINK' ? '#4ade80' : '#a78bfa';
                        document.getElementById('fmLinksNum').textContent = step.linkNum || '-';
                        document.getElementById('fmAgentName').textContent = getAgentName(step.agentNum || 1);
                        document.getElementById('fmFromPortal').textContent = step.originName ? (step.originName + ' (' + step.originNum + ')') : '-';
                        document.getElementById('fmToPortal').textContent = step.destinationName ? (step.destinationName + ' (' + step.destinationNum + ')') : '-';
                        document.getElementById('fmDoneBadge').style.display = 'none';
                    } else {
                        const actionEl = document.getElementById('fmActionType');
                        actionEl.textContent = currentFrame === 0 ? 'INIT' : 'DONE';
                        actionEl.style.background = '#4ade80';
                        document.getElementById('fmLinksNum').textContent = '-';
                        document.getElementById('fmAgentName').textContent = '-';
                        document.getElementById('fmFromPortal').textContent = '-';
                        document.getElementById('fmToPortal').textContent = '-';
                        document.getElementById('fmDoneBadge').style.display = currentFrame > 0 ? 'inline' : 'none';
                    }
                }
                
                window.fmStart = function() { currentFrame = 0; updateUI(); }
                window.fmEnd = function() { currentFrame = totalFrames - 1; updateUI(); }
                window.fmNext = function() { if (currentFrame < totalFrames - 1) { currentFrame++; updateUI(); } }
                window.fmPrev = function() { if (currentFrame > 0) { currentFrame--; updateUI(); } }
                
                updateUI();
            })();
            </script>
            
        </div>
        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="keys">
            <div class="row">
                <div class="col">
                    <h4>Key Preparation Total</h4>
                    <div class="mb-2">
                        <label for="sortKeys">Ordenar por:</label>
                        <select id="sortKeys" {{ stimulus_action('maxfield-view', 'sortKeys', 'change') }}>
                            <option value="mapNo">Map No (default)</option>
                            <option value="keysAsc">Keys ↑ ascendente</option>
                            <option value="keysDesc">Keys ↓ descendente</option>
                            <option value="nameAsc">Nombre A-Z</option>
                            <option value="nameDesc">Nombre Z-A</option>
                        </select>
                    </div>
                    <table>
                        <tr>
                            <th>Map No</th>
                            <th>Keys</th>
                            <th>Tengo</th>
                            <th>Faltan</th>
                            <th>Name</th>
                        </tr>
                        {% set userKeys = maxfield.userData ? maxfield.userData[1].keys is defined ? maxfield.userData[1].keys : [] : [] %}

                        {% for wayPoint in info.keyPrep.wayPoints %}
                            {% set wpGuid = waypointIdMap[wayPoint.mapNo].guid %}
                            {% set myCount = 0 %}
                            {% for k in userKeys %}
                                {% if k.guid == wpGuid %}
                                    {% set myCount = k.count %}
                                {% endif %}
                            {% endfor %}
                            <tr data-map-no="{{ wayPoint.mapNo }}" data-keys="{{ wayPoint.keysNeeded }}" data-name="{{ wayPoint.name|lower }}">
                                <th>{{ wayPoint.mapNo }}</th>
                                <td>{{ wayPoint.keysNeeded }}</td>
                                <td>
                                    <input type="number" min="0" 
                                           data-map-no="{{ wayPoint.mapNo }}"
                                           data-guid="{{ wpGuid }}"
                                           {{ stimulus_action('maxfield-view', 'updateMyKeys', 'change') }}
                                           value="{{ myCount }}"
                                           style="width: 60px;" class="form-control form-control-sm">
                                </td>
                                <td data-faltan>{{ wayPoint.keysNeeded - myCount }}</td>
                                <td>{{ wayPoint.name }}</td>
                            </tr>
                        {% endfor %}
                    </table>
                </div>
            </div>
        </div>

        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="plan-results">
            {% if maxfield.planResults %}
                {# 
                    TEMPORAL: Orion Global Op Event Column
                    - Event dates: 24 abr 2026 - 11 may 2026
                    - Shows points calculation: Links × 2, Fields × 4
                    - Column auto-hides outside event dates via Twig date condition
                    - For future similar events: adjust dates and multipliers in startDate/endDate
                #}
                {% set now = date() %}
                {% set startDate = date('2026-04-24') %}
                {% set endDate = date('2026-05-11 23:59:59') %}
                {% set showEventColumn = now >= startDate and now <= endDate %}

                <div class="row justify-content-center">
                    <div class="col-12 col-lg-6">
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Metric</th>
                                        <th>Value</th>
                                        {% if showEventColumn %}
                                            <th>Orion Global Op (x2 Links, x4 Fields)</th>
                                        {% endif %}
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>Portals</strong></td>
                                        <td>{{ maxfield.planResults.portals }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>Links</strong></td>
                                        <td>{{ maxfield.planResults.links }}</td>
                                        {% if showEventColumn %}
                                            <td>{{ (maxfield.planResults.links * 2)|number_format }}</td>
                                        {% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>Fields</strong></td>
                                        <td>{{ maxfield.planResults.fields }}</td>
                                        {% if showEventColumn %}
                                            <td>{{ (maxfield.planResults.fields * 4)|number_format }}</td>
                                        {% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>Max Keys Needed</strong></td>
                                        <td>{{ maxfield.planResults.max_keys_needed }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>AP from Portals</strong></td>
                                        <td>{{ maxfield.planResults.ap_from_portals|number_format }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>AP from Links</strong></td>
                                        <td>{{ maxfield.planResults.ap_from_links|number_format }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>AP from Fields</strong></td>
                                        <td>{{ maxfield.planResults.ap_from_fields|number_format }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr class="table-success">
                                        <td><strong>TOTAL AP</strong></td>
                                        <td><strong>{{ maxfield.planResults.total_ap|number_format }}</strong></td>
                                        {% if showEventColumn %}
                                            <td><strong>{{ ((maxfield.planResults.links * 2) + (maxfield.planResults.fields * 4))|number_format }}</strong></td>
                                        {% endif %}
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="alert alert-info">
                    No results stored yet.
                </div>
            {% endif %}
        </div>

        {% for agentInfo in info.agentsInfo %}
            <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none"
                                                               data-id="agent-{{ agentInfo.agentNumber }}">
                <div class="row mb-2">
                    <div class="col-auto">
                        <label for="agent-name-{{ agentInfo.agentNumber }}">Nombre Agent:</label>
                        <input type="text" 
                               id="agent-name-{{ agentInfo.agentNumber }}" 
                               class="form-control"
                               placeholder="Agent {{ agentInfo.agentNumber }}"
                               data-agent-num="{{ agentInfo.agentNumber }}"
                               {{ stimulus_action('maxfield-view', 'updateAgentName', 'input') }}>
                    </div>
                    <div class="col">
                        <label for="email-agent-{{ agentInfo.agentNumber }}">Send e-mail to </label>
                        <input type="text" id="email-agent-{{ agentInfo.agentNumber }}">
                        <button class="btn btn-outline-success sendMail" id="{{ agentInfo.agentNumber }}">
                            Send
                        </button>
                        <span id="result-{{ agentInfo.agentNumber }}"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg">
                        <h4>Keys for agent {{ agentInfo.agentNumber }}</h4>
                        <div class="mb-2">
                            <select class="sort-keys-agent" data-agent="{{ agentInfo.agentNumber }}" {{ stimulus_action('maxfield-view', 'sortKeysAgent', 'change') }}>
                                <option value="mapNo">Map No (default)</option>
                                <option value="keysAsc">Keys ↑ ascendente</option>
                                <option value="keysDesc">Keys ↓ descendente</option>
                                <option value="nameAsc">Nombre A-Z</option>
                                <option value="nameDesc">Nombre Z-A</option>
                            </select>
                        </div>
                        <table class="table table-sm" data-agent-table="{{ agentInfo.agentNumber }}">
                            <tr>
                                <th>Map No</th>
                                <th>Keys</th>
                                <th>Tengo</th>
                                <th>Faltan</th>
                                <th>Name</th>
                            </tr>
                            {% for point in agentInfo.keys.wayPoints %}
                                {% if point.agentNum + 1 == agentInfo.agentNumber %}
                                    {% set wpGuid = waypointIdMap[point.mapNo].guid %}
                                    {% set myCount = 0 %}
                                    {% for k in userKeys %}
                                        {% if k.guid == wpGuid %}
                                            {% set myCount = k.count %}
                                        {% endif %}
                                    {% endfor %}
                                    <tr data-map-no="{{ point.mapNo }}" data-keys="{{ point.keysNeeded }}" data-name="{{ point.name|lower }}">
                                        <td>{{ point.mapNo }}</td>
                                        <td>{{ point.keysNeeded ?: '-' }}</td>
                                        <td>
                                            <input type="number" min="0" 
                                                   data-map-no="{{ point.mapNo }}"
                                                   data-guid="{{ wpGuid }}"
                                                   {{ stimulus_action('maxfield-view', 'updateMyKeys', 'change') }}
                                                   value="{{ myCount }}"
                                                   style="width: 50px;" class="form-control form-control-sm">
                                        </td>
                                        <td data-faltan>{{ point.keysNeeded > 0 ? point.keysNeeded - myCount : '-' }}</td>
                                        <td>{{ point.name }}</td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                        </table>
                    </div>
                    <div class="col-lg">
                        <h4>Links for agent {{ agentInfo.agentNumber }}</h4>
                        {% if info.agentsInfo|length > 1 %}
                            <button class="btn btn-outline-primary"
                                    {{ stimulus_target('maxfield-view', 'btnShowForeign') }}
                                    {{ stimulus_action('maxfield-view', 'toggleShowForeign') }}
                            >
                                Hide foreign
                            </button>
                        {% endif %}
                        <table class="table table-sm">
                            {% set origin=-1 %}
                            {% for link in agentInfo.links %}
                                <tr
                                        {% if agentInfo.agentNumber != link.agentNum %}
                                            class="foreign-link"
                                        {% endif %}
                                        style="border-bottom: 1px solid silver;{% if link.originNum != origin %}border-top: 2px solid darkblue;{% endif %}">
                                    <td>{{ link.isEarly ? 'X' : '' }}</td>
                                    <td>{{ link.linkNum }}</td>
                                    <td>
                                        {% if agentInfo.agentNumber != link.agentNum %}
                                        <del>{% endif %}
                                            {% if link.originNum != origin %}
                                                <b>{{ link.originNum }} - {{ link.originName }}</b><br>
                                            {% endif %}
                                            {% set origin = link.originNum %}
                                            L {{ link.destinationNum }} - {{ link.destinationName }}
                                            {% if agentInfo.agentNumber != link.agentNum %}</del>{% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </table>
                    </div>
                </div>
            </div>
        {% endfor %}


     </div>

    <!-- Modal Generar Variante -->
    <div class="modal fade" id="variantModal" tabindex="-1" aria-labelledby="variantModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="variantModalLabel"><i class="bi-shuffle"></i> Generar Variante</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="POST" action="{{ path('maxfield_generate_variant', {'id': maxfield.id}) }}" target="_blank">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="playersNum" class="form-label">Número de Agents</label>
                            <input type="number" class="form-control" id="playersNum" name="playersNum" 
                                   value="{{ info.agentsInfo|length }}" min="1" max="10" required>
                        </div>
                        <small class="text-muted">Se mezclará el orden de los portales para generar una nueva distribución.</small>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-warning">Generar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    function exportMobile(btn, path) {
        // Get agent names from sessionStorage
        const storageKey = 'maxfield-agents-' + path;
        let agentNames = {};
        try {
            const data = sessionStorage.getItem(storageKey);
            if (data) agentNames = JSON.parse(data);
        } catch(e) {}
        
        // Get number of agents from the page data
        const maxFramesEl = document.querySelector('[data-max-frames-value]');
        const stepsData = maxFramesEl ? JSON.parse(maxFramesEl.dataset.stepsValue || '[]') : [];
        // Count unique agents
        const agents = new Set();
        stepsData.forEach(s => { if (s.agentNum) agents.add(s.agentNum); });
        const numAgents = agents.size || 1;
        
        // Build URL with agent names as query params
        const params = new URLSearchParams();
        params.set('count', numAgents.toString());
        for (const [agentNum, name] of Object.entries(agentNames)) {
            params.append('agent[' + agentNum + ']', name);
        }
        
        let url = btn.href;
        if (params.toString()) {
            url += '?' + params.toString();
        }
        
        window.open(url, '_blank');
        return false;
    }
    </script>

    <script>
    // Close variant modal after form submit
    document.querySelector('#variantModal form')?.addEventListener('submit', function() {
        const modalEl = document.getElementById('variantModal');
        if (modalEl) {
            modalEl.style.display = 'none';
            modalEl.classList.remove('show');
            document.body.classList.remove('modal-open');
            const backdrop = document.querySelector('.modal-backdrop');
            if (backdrop) backdrop.remove();
        }
    });
    </script>

{% endblock %}
