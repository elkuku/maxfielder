{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - MaxFields Result{% endblock %}

{% block body %}
    <div class="float-end">
        <a href="{{ path('maxfield_play', {'path': maxfield.path}) }}" class="btn btn-outline-success">Play</a>
        <a href="{{ path('maxfield_export_mobile', {'path': maxfield.path}) }}" 
           class="btn btn-outline-primary" 
           target="_blank"
           onclick="return exportMobile(this, '{{ maxfield.path }}')"
           id="btnMobile"><i class="bi-phone"></i> Mobile</a>
        <a href="{{ path('max_fields_delete', {'id': maxfield.id}) }}" class="btn btn-outline-danger">Delete</a>
    </div>

    <h3>MaxFields for <span id="itemId">{{ maxfield.name }}</span></h3>

    <div
            {{ stimulus_controller('maxfield-view', {
                maxFrames: info.steps|length,
                item: maxfield.path,
                steps: info.steps|json_encode,
            }) }}
    >

        <nav class="nav nav-pills fixed-top bg-dark" id="maxfield-tab-nav">
            <a class="nav-link active" href="#" data-id="maps"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'maps'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                Maps
            </a>
            <a class="nav-link" href="#" data-id="movie"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'movie'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                Movie
            </a>
            <a class="nav-link" href="#" data-id="frames"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'frames'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                Frames
            </a>
            <a class="nav-link" href="#" data-id="keys"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'keys'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}>
                Keys
            </a>
            <a class="nav-link" href="#" data-id="plan-results"
                    {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'plan-results'}) }}
                    {{ stimulus_target('maxfield-view', 'tabBtn') }}
            >
                <i class="fas fa-chart-bar"></i> Plan Results
            </a>

            {% for agentInfo in info.agentsInfo %}
                <a class="nav-link" href="#" data-id="agent-{{ agentInfo.agentNumber }}"
                        {{ stimulus_action('maxfield-view', 'showTab', 'click', {tab:'agent-'~agentInfo.agentNumber}) }}
                        {{ stimulus_target('maxfield-view', 'tabBtn') }}
                        data-agent-num="{{ agentInfo.agentNumber }}"
                >
                    Agent {{ agentInfo.agentNumber }}
                </a>
            {% endfor %}
        </nav>

        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" data-id="maps">
            <div class="row">
                <div class="col">
                    <img src="/maxfields/{{ maxfield.path }}/link_map.png" width="350px" alt="Link Map">
                </div>
                <div class="col">
                    <img src="/maxfields/{{ maxfield.path }}/portal_map.png" width="350px" alt="Portal Map">
                </div>
            </div>
        </div>
        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="movie">
            <img src="/maxfields/{{ maxfield.path }}/plan_movie.gif" width="350px" alt="Link movie">
        </div>
        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="frames">
            <div class="row">
                <div class="col">
                    <button class="btn btn-outline-secondary" {{ stimulus_action('maxfield-view', 'frameMinus') }}>
                        <span class="bi-dash-lg"></span>
                    </button>
                    <button class="btn btn-outline-secondary" {{ stimulus_action('maxfield-view', 'framePlus') }}>
                        <span class="bi-plus-lg"></span>
                    </button>
                    <span {{ stimulus_target('maxfield-view', 'frameNum') }}>#</span>
                    <div {{ stimulus_target('maxfield-view', 'frameLinkInfo') }}>...</div>
                </div>
                <div class="col border">
                    <img {{ stimulus_target('maxfield-view', 'framesImage') }}
                            src="" alt="Frame" width="350px">
                </div>
            </div>
        </div>
        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="keys">
            <div class="row">
                <div class="col">
                    <h4>Key Preparation Total</h4>
                    <div class="mb-2">
                        <label for="sortKeys">Ordenar por:</label>
                        <select id="sortKeys" {{ stimulus_action('maxfield-view', 'sortKeys', 'change') }}>
                            <option value="mapNo">Map No (default)</option>
                            <option value="keysAsc">Keys ↑ ascendente</option>
                            <option value="keysDesc">Keys ↓ descendente</option>
                            <option value="nameAsc">Nombre A-Z</option>
                            <option value="nameDesc">Nombre Z-A</option>
                        </select>
                    </div>
                    <table>
                        <tr>
                            <th>Map No</th>
                            <th>Keys</th>
                            <th>Tengo</th>
                            <th>Faltan</th>
                            <th>Name</th>
                        </tr>
                        {% set userKeys = maxfield.userData ? maxfield.userData[1].keys is defined ? maxfield.userData[1].keys : [] : [] %}

                        {% for wayPoint in info.keyPrep.wayPoints %}
                            {% set wpGuid = waypointIdMap[wayPoint.mapNo].guid %}
                            {% set myCount = 0 %}
                            {% for k in userKeys %}
                                {% if k.guid == wpGuid %}
                                    {% set myCount = k.count %}
                                {% endif %}
                            {% endfor %}
                            <tr data-map-no="{{ wayPoint.mapNo }}" data-keys="{{ wayPoint.keysNeeded }}" data-name="{{ wayPoint.name|lower }}">
                                <th>{{ wayPoint.mapNo }}</th>
                                <td>{{ wayPoint.keysNeeded }}</td>
                                <td>
                                    <input type="number" min="0" 
                                           data-map-no="{{ wayPoint.mapNo }}"
                                           data-guid="{{ wpGuid }}"
                                           {{ stimulus_action('maxfield-view', 'updateMyKeys', 'change') }}
                                           value="{{ myCount }}"
                                           style="width: 60px;" class="form-control form-control-sm">
                                </td>
                                <td data-faltan>{{ wayPoint.keysNeeded - myCount }}</td>
                                <td>{{ wayPoint.name }}</td>
                            </tr>
                        {% endfor %}
                    </table>
                </div>
            </div>
        </div>

        <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none" data-id="plan-results">
            {% if maxfield.planResults %}
                {# 
                    TEMPORAL: Orion Global Op Event Column
                    - Event dates: 24 abr 2026 - 11 may 2026
                    - Shows points calculation: Links × 2, Fields × 4
                    - Column auto-hides outside event dates via Twig date condition
                    - For future similar events: adjust dates and multipliers in startDate/endDate
                #}
                {% set now = date() %}
                {% set startDate = date('2026-04-24') %}
                {% set endDate = date('2026-05-11 23:59:59') %}
                {% set showEventColumn = now >= startDate and now <= endDate %}

                <div class="row justify-content-center">
                    <div class="col-12 col-lg-6">
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Metric</th>
                                        <th>Value</th>
                                        {% if showEventColumn %}
                                            <th>Orion Global Op (x2 Links, x4 Fields)</th>
                                        {% endif %}
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>Portals</strong></td>
                                        <td>{{ maxfield.planResults.portals }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>Links</strong></td>
                                        <td>{{ maxfield.planResults.links }}</td>
                                        {% if showEventColumn %}
                                            <td>{{ (maxfield.planResults.links * 2)|number_format }}</td>
                                        {% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>Fields</strong></td>
                                        <td>{{ maxfield.planResults.fields }}</td>
                                        {% if showEventColumn %}
                                            <td>{{ (maxfield.planResults.fields * 4)|number_format }}</td>
                                        {% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>Max Keys Needed</strong></td>
                                        <td>{{ maxfield.planResults.max_keys_needed }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>AP from Portals</strong></td>
                                        <td>{{ maxfield.planResults.ap_from_portals|number_format }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>AP from Links</strong></td>
                                        <td>{{ maxfield.planResults.ap_from_links|number_format }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr>
                                        <td><strong>AP from Fields</strong></td>
                                        <td>{{ maxfield.planResults.ap_from_fields|number_format }}</td>
                                        {% if showEventColumn %}<td>-</td>{% endif %}
                                    </tr>
                                    <tr class="table-success">
                                        <td><strong>TOTAL AP</strong></td>
                                        <td><strong>{{ maxfield.planResults.total_ap|number_format }}</strong></td>
                                        {% if showEventColumn %}
                                            <td><strong>{{ ((maxfield.planResults.links * 2) + (maxfield.planResults.fields * 4))|number_format }}</strong></td>
                                        {% endif %}
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="alert alert-info">
                    No results stored yet.
                </div>
            {% endif %}
        </div>

        {% for agentInfo in info.agentsInfo %}
            <div {{ stimulus_target('maxfield-view', 'tab') }} class="maxfield-tab" style="display: none"
                                                               data-id="agent-{{ agentInfo.agentNumber }}">
                <div class="row mb-2">
                    <div class="col-auto">
                        <label for="agent-name-{{ agentInfo.agentNumber }}">Nombre Agent:</label>
                        <input type="text" 
                               id="agent-name-{{ agentInfo.agentNumber }}" 
                               class="form-control"
                               placeholder="Agent {{ agentInfo.agentNumber }}"
                               data-agent-num="{{ agentInfo.agentNumber }}"
                               {{ stimulus_action('maxfield-view', 'updateAgentName', 'input') }}>
                    </div>
                    <div class="col">
                        <label for="email-agent-{{ agentInfo.agentNumber }}">Send e-mail to </label>
                        <input type="text" id="email-agent-{{ agentInfo.agentNumber }}">
                        <button class="btn btn-outline-success sendMail" id="{{ agentInfo.agentNumber }}">
                            Send
                        </button>
                        <span id="result-{{ agentInfo.agentNumber }}"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg">
                        <h4>Keys for agent {{ agentInfo.agentNumber }}</h4>
                        <div class="mb-2">
                            <select class="sort-keys-agent" data-agent="{{ agentInfo.agentNumber }}" {{ stimulus_action('maxfield-view', 'sortKeysAgent', 'change') }}>
                                <option value="mapNo">Map No (default)</option>
                                <option value="keysAsc">Keys ↑ ascendente</option>
                                <option value="keysDesc">Keys ↓ descendente</option>
                                <option value="nameAsc">Nombre A-Z</option>
                                <option value="nameDesc">Nombre Z-A</option>
                            </select>
                        </div>
                        <table class="table table-sm" data-agent-table="{{ agentInfo.agentNumber }}">
                            <tr>
                                <th>Map No</th>
                                <th>Keys</th>
                                <th>Tengo</th>
                                <th>Faltan</th>
                                <th>Name</th>
                            </tr>
                            {% for point in agentInfo.keys.wayPoints %}
                                {% if point.agentNum + 1 == agentInfo.agentNumber %}
                                    {% set wpGuid = waypointIdMap[point.mapNo].guid %}
                                    {% set myCount = 0 %}
                                    {% for k in userKeys %}
                                        {% if k.guid == wpGuid %}
                                            {% set myCount = k.count %}
                                        {% endif %}
                                    {% endfor %}
                                    <tr data-map-no="{{ point.mapNo }}" data-keys="{{ point.keysNeeded }}" data-name="{{ point.name|lower }}">
                                        <td>{{ point.mapNo }}</td>
                                        <td>{{ point.keysNeeded ?: '-' }}</td>
                                        <td>
                                            <input type="number" min="0" 
                                                   data-map-no="{{ point.mapNo }}"
                                                   data-guid="{{ wpGuid }}"
                                                   {{ stimulus_action('maxfield-view', 'updateMyKeys', 'change') }}
                                                   value="{{ myCount }}"
                                                   style="width: 50px;" class="form-control form-control-sm">
                                        </td>
                                        <td data-faltan>{{ point.keysNeeded > 0 ? point.keysNeeded - myCount : '-' }}</td>
                                        <td>{{ point.name }}</td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                        </table>
                    </div>
                    <div class="col-lg">
                        <h4>Links for agent {{ agentInfo.agentNumber }}</h4>
                        {% if info.agentsInfo|length > 1 %}
                            <button class="btn btn-outline-primary"
                                    {{ stimulus_target('maxfield-view', 'btnShowForeign') }}
                                    {{ stimulus_action('maxfield-view', 'toggleShowForeign') }}
                            >
                                Hide foreign
                            </button>
                        {% endif %}
                        <table class="table table-sm">
                            {% set origin=-1 %}
                            {% for link in agentInfo.links %}
                                <tr
                                        {% if agentInfo.agentNumber != link.agentNum %}
                                            class="foreign-link"
                                        {% endif %}
                                        style="border-bottom: 1px solid silver;{% if link.originNum != origin %}border-top: 2px solid darkblue;{% endif %}">
                                    <td>{{ link.isEarly ? 'X' : '' }}</td>
                                    <td>{{ link.linkNum }}</td>
                                    <td>
                                        {% if agentInfo.agentNumber != link.agentNum %}
                                        <del>{% endif %}
                                            {% if link.originNum != origin %}
                                                <b>{{ link.originNum }} - {{ link.originName }}</b><br>
                                            {% endif %}
                                            {% set origin = link.originNum %}
                                            L {{ link.destinationNum }} - {{ link.destinationName }}
                                            {% if agentInfo.agentNumber != link.agentNum %}</del>{% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </table>
                    </div>
                </div>
            </div>
        {% endfor %}


    </div>

    <script>
    function exportMobile(btn, path) {
        // Get agent names from sessionStorage
        const storageKey = 'maxfield-agents-' + path;
        let agentNames = {};
        try {
            const data = sessionStorage.getItem(storageKey);
            if (data) agentNames = JSON.parse(data);
        } catch(e) {}
        
        // Get number of agents from the page data
        const maxFramesEl = document.querySelector('[data-max-frames-value]');
        const stepsData = maxFramesEl ? JSON.parse(maxFramesEl.dataset.stepsValue || '[]') : [];
        // Count unique agents
        const agents = new Set();
        stepsData.forEach(s => { if (s.agentNum) agents.add(s.agentNum); });
        const numAgents = agents.size || 1;
        
        // Build URL with agent names as query params
        const params = new URLSearchParams();
        params.set('count', numAgents.toString());
        for (const [agentNum, name] of Object.entries(agentNames)) {
            params.append('agent[' + agentNum + ']', name);
        }
        
        let url = btn.href;
        if (params.toString()) {
            url += '?' + params.toString();
        }
        
        window.open(url, '_blank');
        return false;
    }
    </script>

{% endblock %}
