<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ maxfield.name }} - Mobile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; height: 100%; }
        body { background: #1a1a1a; color: #e0e0e0; font-family: -apple-system, BlinkMacSystemFont, sans-serif; padding-bottom: 70px; }
        
        .tabs { display: flex; background: #262626; position: sticky; top: 0; z-index: 100; }
        .tab-btn { flex: 1; padding: 14px; background: none; border: none; color: #9ca3af; font-size: 14px; cursor: pointer; }
        .tab-btn.active { color: #4ade80; border-bottom: 2px solid #4ade80; }
        .tab-content > div { display: none; }
        .tab-content > div.active { display: block; }
        
        .play-content { padding: 10px; padding-bottom: 80px; overflow-y: auto; height: calc(100vh - 50px); }
        .frame-image { max-width: 100%; height: auto; border-radius: 8px; min-height: 200px; max-height: 50vh; }
        
        .step-info { background: #262626; border-radius: 8px; padding: 10px; margin: 10px 0; }
        .step-info .row { padding: 4px 0; border-bottom: 1px solid #333; }
        .step-info .row:last-child { border-bottom: none; }
        .step-info .label { display: inline-block; min-width: 50px; margin-right: 6px; color: #9ca3af; }
        .step-info .value { display: inline-block; margin-right: 16px; }
        .step-info .inline { display: inline; border-bottom: none; padding-right: 12px; }
        .step-info .agent-name { color: #4ade80; }
        
        .done-badge { display: none; background: #4ade80; color: #1a1a1a; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; margin-left: 8px; }
        .done-badge.active { display: inline; }
        
        .frame-nav { position: fixed; bottom: 0; left: 0; right: 0; background: #2d2d2d; padding: 10px; display: flex; gap: 8px; justify-content: center; z-index: 1000; border-top: 1px solid #404040; }
        .frame-nav button { padding: 10px 16px; border-radius: 6px; }
        
        .keys-list { padding: 10px; padding-bottom: 80px; overflow-y: auto; height: calc(100vh - 50px); }
        .key-row { display: flex; justify-content: space-between; align-items: center; padding: 10px; background: #262626; border-radius: 8px; margin-bottom: 8px; }
        .key-row .name { flex: 1; font-size: 14px; }
        .key-row input { width: 50px; text-align: center; background: #1a1a1a; border: 1px solid #404040; color: #e0e0e0; border-radius: 4px; padding: 6px; }
        
        .reset-btn { width: 100%; padding: 14px; background: #dc3545; color: white; border: none; border-radius: 8px; font-size: 16px; margin-top: 10px; }
        .spacer { height: 60px; }
        
        .progress-bar { height: 3px; background: #333; }
        .progress-bar .fill { height: 100%; background: #4ade80; width: 0%; }
    </style>
</head>
<body>
    <div class="progress-bar"><div class="fill" id="progressFill"></div></div>
    
    <div class="tabs">
        <button class="tab-btn active" data-tab="play">Play</button>
        <button class="tab-btn" data-tab="keys">Keys</button>
    </div>
    
    <div class="tab-content">
        <!-- PLAY TAB -->
        <div class="tab-pane active" id="play">
            <div class="play-content">
                <img id="currentFrame" class="frame-image" src="" alt="Frame">
                <span id="doneBadge" class="done-badge">DONE</span>
                
                <div class="step-info">
                    <div class="row">
                        <span class="label">Action:</span>
                        <span class="value" id="actionType">-</span>
                    </div>
                    <div class="row">
                        <span class="label">Agent:</span>
                        <span class="value agent-name" id="agentName">-</span>
                    </div>
                    <div class="row">
                        <span class="label">#:</span>
                        <span class="value" id="linkNum">-</span>
                    </div>
                    <div class="row">
                        <span class="label">From:</span>
                        <span class="value" id="fromPortal">-</span>
                    </div>
                    <div class="row">
                        <span class="label">To:</span>
                        <span class="value" id="toPortal">-</span>
                    </div>
                </div>
                
                <div class="frame-nav">
                    <button class="btn btn-outline-secondary btn-sm" id="startBtn">Start</button>
                    <button class="btn btn-outline-secondary btn-sm" id="prevBtn">Prev</button>
                    <button class="btn btn-success btn-sm" id="doneBtn">Done</button>
                    <button class="btn btn-outline-secondary btn-sm" id="nextBtn">Next</button>
                </div>
            </div>
        </div>
        
        <!-- KEYS TAB -->
        <div class="tab-pane" id="keys">
            <div class="keys-list">
                {% for wayPoint in info.keyPrep.wayPoints %}
                    <div class="key-row">
                        <span class="name"><strong>{{ wayPoint.mapNo }}</strong>. {{ wayPoint.name[:25] }}{{ wayPoint.name|length > 25 ? '...' : '' }}</span>
                        <span>
                            <input type="number" class="key-input" data-map-no="{{ wayPoint.mapNo }}" value="0" min="0">
                            <span style="color: #9ca3af;">/ {{ wayPoint.keysNeeded }}</span>
                        </span>
                    </div>
                {% endfor %}
                <button class="reset-btn" id="resetBtn">Reset Progress</button>
                <div class="spacer"></div>
            </div>
        </div>
    </div>
    
    <script>
    (function() {
        'use strict';
        
        const STORAGE_KEY = 'maxfield_{{ maxfield.path }}';
        const frames = {{ frames|json_encode|raw }};
        const frameNames = Object.keys(frames);
        const totalFrames = frameNames.length;
        const steps = {{ info.steps|json_encode|raw }};
        const agentNames = {{ agentNames|json_encode|raw }};
        
        let currentFrame = 0;
        
        function loadData() {
            try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
            catch(e) { return {}; }
        }
        
        function saveData(data) {
            try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }
            catch(e) {}
        }
        
        function getAgentName(agentNum) {
            return agentNames[agentNum] || ('Agent ' + agentNum);
        }
        
        const TYPE_LINK = 1, TYPE_MOVE = 2;
        
        function getActionType(step) {
            if (!step) return '-';
            if (step.action === TYPE_LINK || step.linkNum > 0) return 'LINK';
            return 'MOVE';
        }
        
        const frameImg = document.getElementById('currentFrame');
        const actionTypeEl = document.getElementById('actionType');
        const linkNumEl = document.getElementById('linkNum');
        const agentNameEl = document.getElementById('agentName');
        const fromPortalEl = document.getElementById('fromPortal');
        const toPortalEl = document.getElementById('toPortal');
        const doneBtn = document.getElementById('doneBtn');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const startBtn = document.getElementById('startBtn');
        const progressFill = document.getElementById('progressFill');
        const doneBadge = document.getElementById('doneBadge');
        
        function updateUI() {
            if (totalFrames === 0) return;
            
            const name = frameNames[currentFrame];
            frameImg.src = frames[name];
            progressFill.style.width = ((currentFrame + 1) / totalFrames * 100) + '%';
            
            if (steps && steps[currentFrame]) {
                const step = steps[currentFrame];
                const actionType = getActionType(step);
                actionTypeEl.textContent = actionType;
                actionTypeEl.className = 'value ' + (actionType === 'LINK' ? 'type-link' : 'type-move');
                linkNumEl.textContent = step.linkNum || '-';
                agentNameEl.textContent = getAgentName(step.agentNum || 1);
                fromPortalEl.textContent = step.originName ? (step.originName + ' (' + step.originNum + ')') : '-';
                toPortalEl.textContent = step.destinationName ? (step.destinationName + ' (' + step.destinationNum + ')') : '-';
            }
            
            const data = loadData();
            if (data[name]) {
                doneBtn.classList.remove('btn-success');
                doneBtn.classList.add('btn-secondary');
                doneBadge.classList.add('active');
            } else {
                doneBtn.classList.add('btn-success');
                doneBtn.classList.remove('btn-secondary');
                doneBadge.classList.remove('active');
            }
            
            saveData(Object.assign(data, { _current: currentFrame }));
        }
        
        function startOver() { currentFrame = 0; updateUI(); }
        function nextFrame() { if (currentFrame < totalFrames - 1) { currentFrame++; updateUI(); } }
        function prevFrame() { if (currentFrame > 0) { currentFrame--; updateUI(); } }
        
        function markDone() {
            const data = loadData();
            const name = frameNames[currentFrame];
            data[name] = !data[name];
            saveData(data);
            updateUI();
            if (data[name] && currentFrame < totalFrames - 1) setTimeout(nextFrame, 500);
        }
        
        startBtn.addEventListener('click', startOver);
        nextBtn.addEventListener('click', nextFrame);
        prevBtn.addEventListener('click', prevFrame);
        doneBtn.addEventListener('click', markDone);
        
        document.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowRight') nextFrame();
            if (e.key === 'ArrowLeft') prevFrame();
            if (e.key === ' ' || e.key === 'Enter') markDone();
        });
        
        let touchStartX = 0;
        document.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, {passive: true});
        document.addEventListener('touchend', function(e) {
            const diff = e.changedTouches[0].clientX - touchStartX;
            if (Math.abs(diff) > 50) diff > 0 ? prevFrame() : nextFrame();
        }, {passive: true});
        
        document.querySelectorAll('.tab-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
                btn.classList.add('active');
                document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });
                document.getElementById(btn.dataset.tab).classList.add('active');
            });
        });
        
        document.querySelectorAll('.key-input').forEach(function(input) {
            input.addEventListener('change', function() {
                const data = loadData();
                data._keys = data._keys || {};
                data._keys[input.dataset.mapNo] = parseInt(input.value) || 0;
                saveData(data);
            });
            const data = loadData();
            if (data._keys && data._keys[input.dataset.mapNo]) input.value = data._keys[input.dataset.mapNo];
        });
        
        document.getElementById('resetBtn').addEventListener('click', function() {
            if (confirm('Reset all progress?')) { localStorage.removeItem(STORAGE_KEY); location.reload(); }
        });
        
        const savedData = loadData();
        if (savedData._current !== undefined) currentFrame = savedData._current;
        updateUI();
    })();
    </script>
</body>
</html>